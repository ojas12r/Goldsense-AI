# OpenRouter API Key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Vision model selection (optional — default is 7B)
# Options:
#   qwen/qwen-2.5-vl-7b-instruct      ← default (cheap, fast)
#   qwen/qwen2.5-vl-32b-instruct      ← better accuracy
#   qwen/qwen2.5-vl-72b-instruct      ← best (use for demo day)
VISION_MODEL=qwen/qwen-2.5-vl-7b-instruct

# Backend port
PORT=8000
